# Quix yayınlama ayarları — release.sh ve bundle.sh bunu okur.
# Sürüm çıkarırken VERSION/BUILD değerlerini güncelle.

APP_NAME="Quix"
BUNDLE_ID="com.xsdemirbas.quix"

# Sürüm bilgisi
VERSION="1.0.0"     # CFBundleShortVersionString (SemVer, kullanıcıya görünen)
BUILD="1"           # CFBundleVersion (her yayında ARTAN tamsayı)

# İmzalama (Developer ID Application sertifikası oluşturulunca doldur/doğrula)
TEAM_ID="BVCDHS9VW4"
DEVELOPER_ID="Developer ID Application: Sedat DEMİRBAŞ (BVCDHS9VW4)"

# Notarization: önce bir kez kimlik profilini kaydet:
#   xcrun notarytool store-credentials "quix-notary" \
#     --apple-id "APPLE_ID_EMAIL" --team-id "BVCDHS9VW4" --password "APP_SPECIFIC_PASSWORD"
NOTARY_PROFILE="quix-notary"

# Sparkle otomatik güncelleme
SU_PUBLIC_ED_KEY="dn+oa5Nn8zgPy7panM9+Qf8qV478Zi94GEs4+AU9MXM="

# GitHub Releases barındırma
GITHUB_REPO="sdemirbas/quix"
# Appcast repo'nun main dalında raw olarak sunulur (repo PUBLIC olmalı):
SUFEED_URL="https://raw.githubusercontent.com/sdemirbas/quix/main/appcast.xml"
